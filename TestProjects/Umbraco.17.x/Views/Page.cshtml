@using Umbraco.Cms.Web.Common.PublishedModels;
@using BetterIcons.Extensions
@using BetterIcons.Models
@using Umbraco.Cms.Core.Models.Blocks
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Page>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
	Layout = null;
	var featuredIcon = Model.GetIconValue("icon");
	var iconList = Model.Value<BlockListModel>("iconList");
}

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>@Model.Name - BetterIcons Demo</title>
	

	@BetterIconsValue.GetScript()
	
	<style>
		* {
			margin: 0;
			padding: 0;
			box-sizing: border-box;
		}

		body {
			font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
			background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
			min-height: 100vh;
			padding: 2rem;
		}

		.container {
			max-width: 1200px;
			margin: 0 auto;
		}

		.header {
			background: white;
			padding: 2rem;
			border-radius: 12px;
			box-shadow: 0 10px 40px rgba(0,0,0,0.1);
			margin-bottom: 2rem;
			display: flex;
			align-items: center;
			gap: 1.5rem;
		}

		.header-logo {
			width: 80px;
			height: 80px;
			flex-shrink: 0;
		}

		.header-content {
			flex: 1;
		}

		.header-title {
			display: flex;
			align-items: center;
			gap: 0.75rem;
			margin-bottom: 0.5rem;
		}

		.brand-name {
			color: #667eea;
			font-size: 1.8rem;
			font-weight: 700;
			margin: 0;
		}

		h1 {
			color: #333;
			margin-bottom: 0.5rem;
		}

		.subtitle {
			color: #666;
			font-size: 1.1rem;
		}

		.icon-showcase {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
			gap: 1.5rem;
			margin-bottom: 2rem;
		}

		.icon-card {
			background: white;
			padding: 2rem;
			border-radius: 12px;
			box-shadow: 0 4px 20px rgba(0,0,0,0.1);
			text-align: center;
			transition: transform 0.3s ease, box-shadow 0.3s ease;
			display: flex;
			flex-direction: column;
			justify-content: space-between;
			min-height: 200px;
		}

		.icon-card:hover {
			transform: translateY(-5px);
			box-shadow: 0 8px 30px rgba(0,0,0,0.15);
		}

		.icon-display {
			color: #667eea;
			display: flex;
			justify-content: center;
			align-items: center;
			flex-grow: 1;
		}

		.icon-name {
			font-size: 0.9rem;
			color: #666;
			word-break: break-word;
			margin-top: 1rem;
		}

		.content-section {
			background: white;
			padding: 2rem;
			border-radius: 12px;
			box-shadow: 0 10px 40px rgba(0,0,0,0.1);
			margin-bottom: 2rem;
		}

		.two-column-layout {
			display: grid;
			grid-template-columns: 300px 1fr;
			gap: 2rem;
			margin-bottom: 1.5rem;
		}

		.info-box {
			background: #f8f9fa;
			padding: 1.5rem;
			border-radius: 8px;
			display: flex;
			flex-direction: column;
			gap: 1rem;
		}

		.info-box h3 {
			margin: 0 0 0.5rem 0;
			color: #333;
			font-size: 1.1rem;
		}

		.info-item {
			margin: 0;
			color: #555;
			font-size: 0.95rem;
		}

		.info-item strong {
			color: #333;
		}

		.sizes-box {
			background: #f8f9fa;
			padding: 1.5rem;
			border-radius: 8px;
			display: flex;
			flex-wrap: wrap;
			gap: 1.5rem;
			align-items: center;
			justify-content: center;
		}

		.size-item {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 0.5rem;
		}

		.size-label {
			font-size: 0.85rem;
			color: #666;
			font-weight: 500;
		}

		@@media (max-width: 768px) {
			.two-column-layout {
				grid-template-columns: 1fr;
			}
		}

		code {
			background: #f8f9fa;
			padding: 0.2rem 0.5rem;
			border-radius: 4px;
			font-family: 'Courier New', monospace;
			font-size: 0.9rem;
		}

		.footer {
			background: white;
			padding: 2rem;
			border-radius: 12px;
			box-shadow: 0 10px 40px rgba(0,0,0,0.1);
			text-align: center;
			color: #666;
		}

		.footer-logo {
			width: 60px;
			height: 60px;
			margin: 0 auto 1rem;
			display: block;
		}

		.footer h3 {
			color: #667eea;
			margin-bottom: 1rem;
			font-size: 1.5rem;
		}

		.footer p {
			margin: 0.5rem 0;
			line-height: 1.6;
		}

		.footer a {
			color: #667eea;
			text-decoration: none;
			font-weight: 500;
			transition: color 0.3s ease;
		}

		.footer a:hover {
			color: #764ba2;
			text-decoration: underline;
		}

		.footer .attribution {
			padding-top: 1.5rem;
			border-top: 1px solid #e0e0e0;
			font-size: 0.9rem;
		}
	</style>
</head>
<body>
	<div class="container">
		<div class="header">
			<img src="/better-icons.png" alt="BetterIcons Logo" class="header-logo" />
			<div class="header-content">
				<div class="header-title">
					<h1 class="brand-name">BetterIcons</h1>
				</div>
				<p class="subtitle">Powerful icon picker with 200,000+ icons for Umbraco CMS</p>
				<p style="margin: 0.5rem 0 0 0; font-size: 0.9rem; color: #888;">Created by <a href="https://niteshbabu.tech" target="_blank" style="color: #667eea; text-decoration: none; font-weight: 500;">NiteshBabu</a></p>
			</div>
		</div>

		@if (!featuredIcon.IsEmpty)
		{
			<div class="content-section">
				<h2>✨ Your Icon - Multiple Sizes</h2>
				<p style="margin-bottom: 1.5rem; color: #666;">Your selected icon rendered in different sizes:</p>
				<div class="two-column-layout">
					<div class="info-box">
						<h3>Icon Information</h3>
						<p class="info-item"><strong>Icon:</strong> @featuredIcon.Icon</p>
						<p class="info-item"><strong>Color:</strong> @featuredIcon.Color</p>
						<p class="info-item"><strong>Collection:</strong> @featuredIcon.Icon.Split(':').FirstOrDefault()</p>
					</div>
					<div class="sizes-box">
						<div class="size-item">
							@featuredIcon.Render(size: 24)
							<span class="size-label">24px</span>
						</div>
						<div class="size-item">
							@featuredIcon.Render(size: 32)
							<span class="size-label">32px</span>
						</div>
						<div class="size-item">
							@featuredIcon.Render(size: 48)
							<span class="size-label">48px</span>
						</div>
						<div class="size-item">
							@featuredIcon.Render(size: 64)
							<span class="size-label">64px</span>
						</div>
						<div class="size-item">
							@featuredIcon.Render(size: 96)
							<span class="size-label">96px</span>
						</div>
					</div>
				</div>
			</div>
		}
		else
		{
			<div class="content-section">
				<p style="color: #666;">No icon selected for this page. Please select an icon in the Umbraco backoffice to see it rendered here.</p>
			</div>
		}
		
		@* Icon List from Blocklist *@
		@if (iconList != null && iconList.Any())
		{
			<div class="content-section">
				<h2>Your Icon List</h2>
				<p style="margin-bottom: 1.5rem; color: #666;">Icons from the iconList blocklist property:</p>
				<div class="icon-showcase">
					@foreach (var block in iconList)
					{
						var blockIcon = block.Content.GetIconValue("icon");
						var blockLabel = block.Content.Value<string>("label");
						
						if (!blockIcon.IsEmpty)
						{
							<div class="icon-card">
								<div class="icon-display">
									@blockIcon.Render(size: 64)
								</div>
								<div class="icon-name">
									@if (!string.IsNullOrWhiteSpace(blockLabel))
									{
										<strong>@blockLabel</strong><br />
									}
									@blockIcon.Icon
								</div>
							</div>
						}
					}
				</div>
			</div>
		}
		
		<div class="content-section">
			<h2>Icon Showcase - 200,000+ Icons Available</h2>
			<p style="margin-bottom: 1.5rem; color: #666;">Explore a diverse collection from 150+ popular icon sets:</p>
			<div class="icon-showcase">
				<div class="icon-card">
					<div class="icon-display">
						<span class="iconify" data-icon="mdi:home" style="color: #3498db; font-size: 64px;"></span>
					</div>
					<div class="icon-name">mdi:home</div>
				</div>
				<div class="icon-card">
					<div class="icon-display">
						<span class="iconify" data-icon="fa-solid:heart" style="color: #e74c3c; font-size: 64px;"></span>
					</div>
					<div class="icon-name">fa-solid:heart</div>
				</div>
				<div class="icon-card">
					<div class="icon-display">
						<span class="iconify" data-icon="bi:lightning-fill" style="color: #f39c12; font-size: 64px;"></span>
					</div>
					<div class="icon-name">bi:lightning-fill</div>
				</div>
				<div class="icon-card">
					<div class="icon-display">
						<span class="iconify" data-icon="heroicons:sparkles" style="color: #9b59b6; font-size: 64px;"></span>
					</div>
					<div class="icon-name">heroicons:sparkles</div>
				</div>
				<div class="icon-card">
					<div class="icon-display">
						<span class="iconify" data-icon="lucide:rocket" style="color: #e67e22; font-size: 64px;"></span>
					</div>
					<div class="icon-name">lucide:rocket</div>
				</div>
				<div class="icon-card">
					<div class="icon-display">
						<span class="iconify" data-icon="tabler:star-filled" style="color: #f1c40f; font-size: 64px;"></span>
					</div>
					<div class="icon-name">tabler:star-filled</div>
				</div>
				<div class="icon-card">
					<div class="icon-display">
						<span class="iconify" data-icon="ph:cloud-sun-fill" style="color: #16a085; font-size: 64px;"></span>
					</div>
					<div class="icon-name">ph:cloud-sun-fill</div>
				</div>
				<div class="icon-card">
					<div class="icon-display">
						<span class="iconify" data-icon="ri:fire-fill" style="color: #c0392b; font-size: 64px;"></span>
					</div>
					<div class="icon-name">ri:fire-fill</div>
				</div>
				<div class="icon-card">
					<div class="icon-display">
						<span class="iconify" data-icon="ic:baseline-shopping-cart" style="color: #27ae60; font-size: 64px;"></span>
					</div>
					<div class="icon-name">ic:baseline-shopping-cart</div>
				</div>
				<div class="icon-card">
					<div class="icon-display">
						<span class="iconify" data-icon="mdi:account-circle" style="color: #8e44ad; font-size: 64px;"></span>
					</div>
					<div class="icon-name">mdi:account-circle</div>
				</div>
				<div class="icon-card">
					<div class="icon-display">
						<span class="iconify" data-icon="fa6-solid:bell" style="color: #f39c12; font-size: 64px;"></span>
					</div>
					<div class="icon-name">fa6-solid:bell</div>
				</div>
				<div class="icon-card">
					<div class="icon-display">
						<span class="iconify" data-icon="carbon:email" style="color: #2980b9; font-size: 64px;"></span>
					</div>
					<div class="icon-name">carbon:email</div>
				</div>
				<div class="icon-card">
					<div class="icon-display">
						<span class="iconify" data-icon="ion:settings-sharp" style="color: #7f8c8d; font-size: 64px;"></span>
					</div>
					<div class="icon-name">ion:settings-sharp</div>
				</div>
				<div class="icon-card">
					<div class="icon-display">
						<span class="iconify" data-icon="bi:folder-fill" style="color: #e67e22; font-size: 64px;"></span>
					</div>
					<div class="icon-name">bi:folder-fill</div>
				</div>
				<div class="icon-card">
					<div class="icon-display">
						<span class="iconify" data-icon="uil:calendar-alt" style="color: #16a085; font-size: 64px;"></span>
					</div>
					<div class="icon-name">uil:calendar-alt</div>
				</div>
			</div>
		</div>

		<div class="footer">
			<img src="/better-icons.png" alt="BetterIcons Logo" class="footer-logo" />
			<h3>BetterIcons</h3>
			<p>A powerful icon picker for Umbraco CMS with access to 200,000+ icons from popular icon sets.</p>
			<p>
				<a href="https://github.com/niteshbabu/Umbraco.Community.BetterIcons" target="_blank">GitHub</a> |
				<a href="https://marketplace.umbraco.com/package/umbraco.community.bettericons" target="_blank">Umbraco Marketplace</a> |
				<a href="https://www.nuget.org/packages/Umbraco.Community.BetterIcons" target="_blank">NuGet</a>
			</p>
			<div class="attribution">
			
				<p style="margin-top: 1rem;">
					<strong>Created by <a href="https://niteshbabu.tech" target="_blank" style="color: #667eea; text-decoration: none;">NiteshBabu</a></strong> | Licensed under MIT
				</p>
			</div>
		</div>
	</div>
</body>
</html>