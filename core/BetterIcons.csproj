<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFrameworks>net7.0;net8.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
    
    <GenerateEmbeddedFilesManifest>true</GenerateEmbeddedFilesManifest>
    <StaticWebAssetBasePath>/</StaticWebAssetBasePath>
    
    <!-- Package Information -->
    <PackageId>Umbraco.Community.BetterIcons</PackageId>
    <Version>1.0.0</Version>
    <Authors>NiteshBabu</Authors>
    <Description>BetterIcons for Umbraco CMS - Choose from thousands of icons from popular icon sets</Description>
    <PackageTags>umbraco;plugin;property-editors;icons;icon-picker;umbraco-marketplace</PackageTags>
    <PackageProjectUrl>https://github.com/niteshbabu/Umbraco.Community.BetterIcons</PackageProjectUrl>
    <RepositoryUrl>https://github.com/niteshbabu/Umbraco.Community.BetterIcons</RepositoryUrl>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>NUGET_README.md</PackageReadmeFile>
    <PackageIcon>better-icons.png</PackageIcon>
  </PropertyGroup>



  <ItemGroup Condition="'$(TargetFramework)' == 'net7.0'">
    <PackageReference Include="Umbraco.Cms.Core" Version="11.0.0" PrivateAssets="All" />
    <PackageReference Include="Umbraco.Cms.Web.BackOffice" Version="11.0.0" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="Umbraco.Cms.Core" Version="13.0.0" PrivateAssets="All" />
    <PackageReference Include="Umbraco.Cms.Web.BackOffice" Version="13.0.0" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\NUGET_README.md" Pack="true" PackagePath="\" />
    <None Include="..\better-icons.png" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
